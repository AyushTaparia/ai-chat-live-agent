# Express server port (defaults to 3000)
PORT=3000

# SQLite database path (defaults to file:./dev.db)
DATABASE_URL="file:./dev.db"

# LLM Providers - Configure AT LEAST ONE key to enable the AI agent.
# The server dynamically detects which key is present in order of priority:
# 1. Gemini (gemini-2.5-flash)
# 2. OpenAI (gpt-4o-mini)
# 3. Anthropic (claude-3-haiku)

GEMINI_API_KEY=your_google_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_claude_api_key_here
